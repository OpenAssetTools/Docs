{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://openassettools.dev/schema/font/iw3.v1.json",
  "type": "object",
  "required": ["_game", "_version"],
  "properties": {
    "_game": {
      "const": "iw3"
    },
    "_version": {
      "const": 1
    }
  },
  "oneOf": [
    {
      "type": "object",
      "required": ["file"],
      "properties": {
        "file": {
          "type": "string"
        },
        "fontSize": {
          "type": "integer",
          "minimum": 0
        },
        "yOffset": {
          "type": "integer"
        },
        "generatedMaterialName": {
          "type": "string"
        },
        "generatedGlowMaterialName": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "required": ["pixelHeight", "material", "glyphs"],
      "properties": {
        "pixelHeight": {
          "type": "integer",
          "minimum": 0
        },
        "material": {
          "type": "string"
        },
        "glowMaterial": {
          "type": "string"
        },
        "glyphs": {
          "type": "array",
          "minItems": 96,
          "items": {
            "$ref": "http://openassettools.dev/schema/font/common.v1.json#/definitions/Glyph"
          }
        }
      }
    }
  ]
}
