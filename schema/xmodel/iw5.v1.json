{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://openassettools.dev/schema/xmodel/iw5.v1.json",
  "type": "object",
  "required": ["_game", "_version", "lods", "flags"],
  "properties": {
    "_game": {
      "const": "iw5"
    },
    "_version": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2
    },
    "type": {
      "enum": ["rigid", "animated", "viewhands"]
    },
    "lods": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "$ref": "#/definitions/XModelLod"
      }
    },
    "collLod": {
      "type": "number",
      "minimum": 0,
      "maximum": 3
    },
    "rootBoneName": {
      "type": "string",
      "description": "Specifies the name of the root bone when the model file does not specify an armature."
    },
    "physPreset": {
      "type": "string"
    },
    "physCollmap": {
      "type": "string"
    }
  },
  "definitions": {
    "XModelLod": {
      "type": "object",
      "required": ["file", "distance"],
      "properties": {
        "file": {
          "type": "string"
        },
        "distance": {
          "type": "number"
        }
      }
    }
  }
}
