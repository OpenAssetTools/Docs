{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://openassettools.dev/schema/font.v1.json",
  "title": "OpenAssetTools font json schema",
  "type": "object",
  "required": ["_game", "_type", "_version"],
  "properties": {
    "_game": {
      "enum": ["iw3", "iw4", "iw5", "t5"]
    },
    "_type": {
      "const": "font"
    },
    "_version": {
      "type": "integer",
      "minimum": 1
    }
  },
  "oneOf": [
    { "$ref": "http://openassettools.dev/schema/font/iw3.v1.json" },
    { "$ref": "http://openassettools.dev/schema/font/iw4.v1.json" },
    { "$ref": "http://openassettools.dev/schema/font/iw5.v1.json" },
    { "$ref": "http://openassettools.dev/schema/font/t5.v1.json" }
  ]
}
